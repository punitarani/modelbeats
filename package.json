{
  "name": "rankedmodel",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24",
    "bun": ">=1.3"
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "dev": "bun run --filter '@rankedmodel/web' dev",
    "build": "bun run --filter '@rankedmodel/web' build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "typescript": "^6.0.2"
  }
}
