{
  "name": "modelbeats",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts"
  ],
  "engines": {
    "node": ">=24",
    "bun": ">=1.3"
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "validate-data": "bun scripts/src/validate.ts",
    "generate-dataset": "bun scripts/src/generate-dataset.ts corpus data",
    "build-catalog": "bun scripts/src/build-catalog.ts",
    "ci": "bun run build-catalog && bun run typecheck && bun run lint && bun run test && bun run build && bun run budgets",
    "dev": "bun run build-catalog && bun run --filter '@modelbeats/web' dev",
    "build": "bun run --filter '@modelbeats/web' build",
    "derive": "bun scripts/src/derive.ts",
    "e2e": "bun run build-catalog && bun run --filter '@modelbeats/web' test:e2e",
    "budgets": "bun scripts/src/check-budgets.ts",
    "deploy:production": "bun scripts/src/deploy.ts production"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "typescript": "^6.0.2"
  }
}
